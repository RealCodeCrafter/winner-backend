NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# * = hammaga ochiq | keyin: http://localhost:5173,https://winner.uz
CORS_ORIGIN=*

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=winner_db
DB_SYNCHRONIZE=true
DB_POOL_MAX=10

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Faqat .env faylida saqlang — git ga commit qilmang
SUPERADMIN_USERNAME=your-username
SUPERADMIN_PASSWORD=your-strong-password

# Rate limit (1 daqiqada)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Contact forma — email orqali yuboriladi (bazaga yozilmaydi)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
CONTACT_EMAIL=info@winner.uz
