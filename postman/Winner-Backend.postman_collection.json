{
  "info": {
    "_postman_id": "winner-backend-api-collection",
    "name": "Winner Backend API",
    "description": "Winner lubricants backend API\n\nBase URL: https://backend.winnerlub.uz/api\n\n1. Avval **Auth → Login** ni ishga tushiring — token avtomatik saqlanadi\n2. Category/Product yaratishda **form-data** ishlatiladi\n3. Texnik maydonlar JSON array: istalgancha qiymat, masalan [\"5W-40\"] yoki [\"5W-40\", \"SAE J 300\"]",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://backend.winnerlub.uz/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": "1"
    },
    {
      "key": "productId",
      "value": "1"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.collectionVariables.set('token', json.accessToken);",
                  "        console.log('Token saqlandi');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"winner_admin\",\n  \"password\": \"your-password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Superadmin login. Javobdagi `accessToken` avtomatik `{{token}}` ga saqlanadi."
          },
          "response": []
        },
        {
          "name": "Update Superadmin",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"winner_admin\",\n  \"currentPassword\": \"your-current-password\",\n  \"newPassword\": \"your-new-password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/update",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "update"]
            },
            "description": "Superadmin username yoki parolini yangilash. Bearer token talab qilinadi."
          },
          "response": []
        }
      ]
    },
    {
